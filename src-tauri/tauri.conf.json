{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "cs2-rcon-panel",
  "version": "0.1.2",
  "identifier": "com.cs2.rcon.panel",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3030",
    "beforeDevCommand": "npx next dev -p 3030",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CS2 RCON Panel",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
